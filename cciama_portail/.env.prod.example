# ── Variables à renseigner dans Dokploy (onglet « Environment » du service Compose) ──
# Copie/colle ces clés dans Dokploy en remplaçant les valeurs « change-moi ».

# Base de données interne (le backend s'y connecte via le réseau compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-moi-mot-de-passe-fort
POSTGRES_DB=cciama_db

# Secret JWT du backend — OBLIGATOIRE (longue chaîne aléatoire)
JWT_SECRET=change-moi-longue-chaine-aleatoire

# URL publique de l'API, FIGÉE dans le build du front — OBLIGATOIRE
# = le domaine donné au service "backend" dans Dokploy, suffixé par /api/v1
VITE_API_URL=https://api.ton-domaine.example/api/v1

# ── MinIO (médias) ──
# Valeurs par défaut OK pour démarrer. Les uploads fonctionnent, MAIS les URLs
# générées pointent en interne (minio:9000) et ne s'affichent pas dans le navigateur.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-moi
MINIO_BUCKET_NAME=cciama-uploads
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# Pour rendre les médias publics : donne un domaine au service "minio" (port 9000)
# dans Dokploy, puis remplace les 3 lignes ci-dessus par :
#   MINIO_ENDPOINT=media.ton-domaine.example
#   MINIO_PORT=443
#   MINIO_USE_SSL=true

# ── Assistant IA (Groq) ──
# Active le chatbot du portail. Sans la clé, le site fonctionne mais l'assistant
# renvoie « non configuré » (503). La clé reste UNIQUEMENT côté backend.
# Récupère/régénère la clé sur https://console.groq.com (format gsk_...).
GROQ_API_SECRET=gsk_change-moi
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Optionnel : Redis / RabbitMQ / Meilisearch / Keycloak ──
# Inutiles pour démarrer (le code a des défauts inoffensifs et ne plante pas sans eux).
