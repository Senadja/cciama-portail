# Application Configuration
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# Database Configuration (PostgreSQL & Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5439/cciama_db?schema=public"

# Keycloak Authentication Configuration
KEYCLOAK_AUTH_SERVER_URL="http://localhost:8080"
KEYCLOAK_REALM="cciama"
KEYCLOAK_CLIENT_ID="cciama-backend"
KEYCLOAK_SECRET="keycloak_client_secret_placeholder"

# Cache Configuration (Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Object Storage Configuration (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=cciama-uploads

# Queue Configuration (RabbitMQ)
RABBITMQ_URI="amqp://guest:guest@localhost:5672"

# Search Configuration (Meilisearch)
MEILI_HOST="http://localhost:7701"
MEILI_API_KEY="meilisearch_master_key_123456"
